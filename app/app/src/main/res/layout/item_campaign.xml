<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/white">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:background="#E0E0E0"
            android:src="@drawable/ic_donasi"
            app:tint="@color/white"
            android:scaleType="center" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvJudulKampanye"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Judul Kampanye Kemanusiaan"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/text_dark"/>

            <!-- Progress Bar (Normal Flow 5) -->
            <ProgressBar
                android:id="@+id/pbKampanye"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:max="100"
                android:progress="0"
                android:progressTint="@color/orange_primary"/>

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp">
                <TextView
                    android:id="@+id/tvTerkumpulDana"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Terkumpul: Rp0"
                    android:textSize="12sp"
                    android:textColor="@color/orange_primary"
                    android:textStyle="bold"/>
                <TextView
                    android:id="@+id/tvSisaTarget"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentRight="true"
                    android:text="Target: Rp0"
                    android:textSize="12sp"
                    android:textColor="@color/text_gray"/>
            </RelativeLayout>

            <Button
                android:layout_width="match_parent"
                android:layout_height="45dp"
                android:layout_marginTop="12dp"
                android:text="Donasi Sekarang"
                android:textSize="12sp"
                android:backgroundTint="@color/orange_primary"
                android:textColor="@color/white"
                android:clickable="false"
                android:focusable="false"/>
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>