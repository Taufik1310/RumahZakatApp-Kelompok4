<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <!-- BOTTOM NAVIGATION -->
    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="65dp"
        android:layout_alignParentBottom="true"
        android:background="@color/white"
        android:elevation="8dp"
        android:orientation="horizontal">

        <LinearLayout
            android:id="@+id/navBeranda"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_home"
                app:tint="@color/orange_primary"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Beranda" android:textSize="12sp" android:textColor="@color/orange_primary" android:textStyle="bold"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navDonasi"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_donasi"
                app:tint="@color/text_gray"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Donasi" android:textSize="12sp" android:textColor="@color/text_gray"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navPenyaluran"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_penyaluran"
                app:tint="@color/text_gray"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Penyaluran" android:textSize="12sp" android:textColor="@color/text_gray"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navProfil"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_profil"
                app:tint="@color/text_gray"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Profil" android:textSize="12sp" android:textColor="@color/text_gray"/>
        </LinearLayout>
    </LinearLayout>

    <!-- KONTEN UTAMA -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/bottomNav">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <!-- HEADER SECTION -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/orange_primary"
                android:orientation="vertical"
                android:padding="20dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <!-- Avatar menggunakan ikon profil -->
                    <ImageView
                        android:id="@+id/ivAvatar"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/ic_launcher_background"
                        android:src="@drawable/ic_profil"
                        app:tint="@color/white"
                        android:padding="8dp"/>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_toRightOf="@id/ivAvatar"
                        android:layout_marginLeft="12dp"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Selamat Siang"
                            android:textSize="12sp"
                            android:textColor="@color/text_light"/>
                        <TextView
                            android:id="@+id/tvNamaDashboard"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Donatur Baik"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/white"/>
                    </LinearLayout>

                    <!-- Ikon Notifikasi -->
                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_alignParentRight="true"
                        android:layout_centerVertical="true"
                        android:src="@drawable/ic_notifikasi"
                        app:tint="@color/white"/>
                </RelativeLayout>

                <TextView
                    android:id="@+id/tvTotalDonasiDashboard"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="Rp 0"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total donasi Anda"
                    android:textSize="12sp"
                    android:textColor="@color/text_light"/>

                <Button
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_marginTop="16dp"
                    android:backgroundTint="@color/white"
                    android:textColor="@color/orange_primary"
                    android:text="Donasi Saya ➔"
                    android:textSize="12sp"/>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E0E0E0" />

            <!-- MENU STATUS & LACAK -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="Status Pembayaran"
                    android:drawableLeft="@drawable/ic_donasi"
                    android:drawableTint="@color/text_gray"
                    android:textColor="@color/text_gray"
                    android:textStyle="bold"/>

                <View
                    android:layout_width="1dp"
                    android:layout_height="match_parent"
                    android:layout_marginHorizontal="10dp"
                    android:background="#E0E0E0" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="Lacak Penyaluran"
                    android:drawableLeft="@drawable/ic_penyaluran"
                    android:drawableTint="@color/text_gray"
                    android:textColor="@color/text_gray"
                    android:textStyle="bold"/>
            </LinearLayout>

            <!-- AKSES CEPAT -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="20dp"
                android:paddingTop="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Akses Cepat"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_dark"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentRight="true"
                    android:text="Edit Item"
                    android:textColor="@color/orange_primary"
                    android:textStyle="bold"/>
            </RelativeLayout>

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:paddingHorizontal="16dp"
                android:paddingTop="12dp"
                android:paddingBottom="24dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Tombol Infak dengan app:icon -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnMenuDonasi"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        app:strokeColor="#E0E0E0"
                        android:textColor="@color/orange_primary"
                        app:icon="@drawable/ic_infak"
                        app:iconTint="@color/orange_primary"
                        android:text="Infak Subuh"/>

                    <!-- Tombol Superqurban dengan app:icon -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnMenuKurban"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        app:strokeColor="#E0E0E0"
                        android:textColor="@color/orange_dark"
                        app:icon="@drawable/ic_kurban"
                        app:iconTint="@color/orange_dark"
                        android:text="Superqurban"/>

                    <!-- Tombol Kalkulator Zakat dengan app:icon -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnMenuZakat"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        app:strokeColor="#E0E0E0"
                        android:textColor="#00796B"
                        app:icon="@drawable/ic_kalkulator"
                        app:iconTint="#00796B"
                        android:text="Kalkulator Zakat"/>
                </LinearLayout>
            </HorizontalScrollView>

            <!-- TATA KELOLA LEMBAGA -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tata kelola Lembaga"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/text_dark"
                android:paddingHorizontal="20dp"
                android:layout_marginBottom="12dp"/>

            <androidx.cardview.widget.CardView
                android:id="@+id/cvTataKelola"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFF0F5">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <!-- Ikon Handshake menggunakan Vector Asset -->
                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/ic_launcher_background"
                        android:src="@drawable/ic_tatakelola"
                        app:tint="@color/white"
                        android:padding="8dp"
                        android:layout_marginEnd="12dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tata kelola Lembaga"
                            android:textStyle="bold"
                            android:textColor="@color/text_dark"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Lihat Laporan, legalitas, serta Audit Syariah lembaga dalam 1 Aplikasi."
                            android:textSize="12sp"
                            android:textColor="@color/text_gray"/>
                    </LinearLayout>

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_home"
                        android:rotation="270"
                        app:tint="@color/text_dark"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </ScrollView>
</RelativeLayout>