<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:background="#FFF5ED">

        <TextView
            android:id="@+id/tvDetailJenis"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Jenis Hewan"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/orange_primary"/>

        <TextView
            android:id="@+id/tvDetailTipe"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tipe Produk"
            android:textColor="@color/text_gray"
            android:layout_marginTop="4dp"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Tahap 1: Pengadaan -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✅ Tahap 1: Pengadaan &amp; Kesehatan"
                android:textStyle="bold"
                android:textColor="@color/text_dark"
                android:textSize="16sp"/>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Hewan kurban telah lolos uji dokter hewan (veteriner) dan berada di kandang karantina."
                android:textColor="@color/text_gray"
                android:layout_marginStart="24dp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="24dp"/>

            <!-- Tahap 2: Penyembelihan -->
            <TextView
                android:id="@+id/tvStatusTahap2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⏳ Tahap 2: Proses Penyembelihan"
                android:textStyle="bold"
                android:textColor="@color/text_dark"
                android:textSize="16sp"/>

            <!-- EXCEPTION 5E: Pesan Jaringan -->
            <TextView
                android:id="@+id/tvPesanDokumentasi"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Hewan Anda telah disembelih secara sah. Dokumentasi visual sedang diproses karena kendala jaringan di lokasi."
                android:textColor="@color/error_red"
                android:layout_marginStart="24dp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="24dp"/>

            <!-- Tahap 3: Logistik / Penebaran -->
            <TextView
                android:id="@+id/tvStatusTahap3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📦 Tahap 3: Pelacakan Logistik"
                android:textStyle="bold"
                android:textColor="@color/text_dark"
                android:textSize="16sp"/>

            <!-- EXCEPTION 6E ATAU ALTERNATE FLOW 6A -->
            <TextView
                android:id="@+id/tvPesanLogistik"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Data pelacakan kurir sedang dalam pemeliharaan."
                android:textColor="@color/orange_primary"
                android:layout_marginStart="24dp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="24dp"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>