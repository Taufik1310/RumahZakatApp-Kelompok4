<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_light">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/white"
        android:padding="16dp"
        android:elevation="4dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Detail Donasi"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/text_dark" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Anda akan berdonasi untuk:"
            android:textColor="@color/text_gray"
            android:textSize="12sp"/>

        <TextView
            android:id="@+id/tvNamaKampanye"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nama Kampanye"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/orange_primary"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nominal Donasi (Min. Rp 1.000)"
            android:textColor="@color/text_dark"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <EditText
            android:id="@+id/etNominalDonasi"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:hint="Contoh: 50000"
            android:inputType="number"
            android:padding="16dp"
            android:background="@android:drawable/edit_text"
            android:layout_marginBottom="16dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sembunyikan nama saya"
                    android:textStyle="bold"
                    android:textColor="@color/text_dark"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tampil sebagai Hamba Allah"
                    android:textSize="12sp"
                    android:textColor="@color/text_gray"/>
            </LinearLayout>

            <Switch
                android:id="@+id/swAnonim"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <Button
            android:id="@+id/btnProsesDonasi"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Lanjutkan Pembayaran"
            android:backgroundTint="@color/orange_primary"
            android:textColor="@color/white"
            android:textStyle="bold"/>
    </LinearLayout>
</LinearLayout>