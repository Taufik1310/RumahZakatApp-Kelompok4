<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_light">

    <!-- Header -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:background="@color/white" android:padding="16dp" android:elevation="4dp">
        <TextView android:id="@+id/btnBackBayar" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⬅" android:textSize="24sp" android:textColor="@color/text_dark" android:layout_marginEnd="16dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Detail Donasi" android:textSize="18sp" android:textStyle="bold" android:textColor="@color/text_dark" />
    </LinearLayout>

    <ScrollView android:layout_width="match_parent" android:layout_height="match_parent">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="20dp">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Anda akan berdonasi untuk:" android:textColor="@color/text_gray" android:textSize="12sp"/>
            <TextView android:id="@+id/tvNamaKampanye" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Nama Kampanye" android:textSize="18sp" android:textStyle="bold" android:textColor="@color/orange_primary" android:layout_marginBottom="24dp"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Nominal Donasi" android:textColor="@color/text_dark" android:textStyle="bold" android:layout_marginBottom="8dp"/>
            <EditText android:id="@+id/etNominalDonasi" android:layout_width="match_parent" android:layout_height="60dp" android:hint="Contoh: 50000" android:inputType="number" android:padding="16dp" android:background="@android:drawable/edit_text"/>

            <!-- Pesan Peringatan Exceptional Flow 6E -->
            <TextView android:id="@+id/tvErrorNominal" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Nominal minimal Rp1.000" android:textColor="@color/error_red" android:textSize="12sp" android:layout_marginBottom="16dp" android:visibility="gone"/>

            <!-- Opsi Privasi & Donasi Rutin -->
            <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="wrap_content" app:cardCornerRadius="8dp" app:cardElevation="0dp" app:cardBackgroundColor="#FFF5ED" android:layout_marginBottom="24dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="12dp">
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Sembunyikan nama saya" android:textStyle="bold" android:textColor="@color/text_dark"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Tampil sebagai Hamba Allah (Anonim)" android:textSize="12sp" android:textColor="@color/text_gray"/>
                        </LinearLayout>
                        <Switch android:id="@+id/swAnonim" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    </LinearLayout>

                    <!-- Opsi Donasi Rutin (Alternate Flow 6A) -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Jadikan Donasi Rutin Bulanan" android:textStyle="bold" android:textColor="@color/text_dark"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Sistem akan mengatur pemotongan otomatis" android:textSize="12sp" android:textColor="@color/text_gray"/>
                        </LinearLayout>
                        <CheckBox android:id="@+id/cbDonasiRutin" android:layout_width="wrap_content" android:layout_height="wrap_content" android:buttonTint="@color/orange_primary"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Metode Pembayaran (Normal Flow 7) -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Pilih Metode Pembayaran" android:textColor="@color/text_dark" android:textStyle="bold" android:layout_marginBottom="8dp"/>
            <RadioGroup android:id="@+id/rgMetodeBayar" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="24dp">
                <RadioButton android:id="@+id/rbBank" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Transfer Bank (Virtual Account)" android:buttonTint="@color/orange_primary" android:checked="true"/>
                <RadioButton android:id="@+id/rbEWallet" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="E-Wallet (GoPay / OVO / Dana)" android:buttonTint="@color/orange_primary"/>
            </RadioGroup>

            <Button android:id="@+id/btnProsesDonasi" android:layout_width="match_parent" android:layout_height="60dp" android:text="Lanjutkan Pembayaran" android:backgroundTint="@color/orange_primary" android:textColor="@color/white" android:textStyle="bold"/>
        </LinearLayout>
    </ScrollView>
</LinearLayout>