<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_light">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/white"
        android:padding="16dp"
        android:elevation="4dp"
        android:gravity="center_vertical">
        <TextView
            android:id="@+id/btnBackTransparansi"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⬅"
            android:textSize="24sp"
            android:textColor="@color/text_dark"
            android:layout_marginEnd="16dp"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tata Kelola Lembaga"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/text_dark" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Laporan Kinerja Makro Nasional"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/orange_primary"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Data agregat serapan dana ZISWAF secara real-time."
                android:textSize="12sp"
                android:textColor="@color/text_gray"
                android:layout_marginBottom="12dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="24dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#E3F2FD">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp"
                        android:gravity="center">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Penerima Manfaat" android:textSize="12sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="1.2Jt Jiwa" android:textStyle="bold" android:textSize="16sp" android:textColor="#1565C0"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#E8F5E9">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp"
                        android:gravity="center">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Dana Tersalurkan" android:textSize="12sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Rp 245 M" android:textStyle="bold" android:textSize="16sp" android:textColor="#2E7D32"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E0E0E0" android:layout_marginBottom="24dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pilih Tahun Buku Laporan Terintegrasi"
                android:textStyle="bold"
                android:textColor="@color/text_dark"
                android:layout_marginBottom="12dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">
                <Button
                    android:id="@+id/btnTahun2024"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="2024"
                    android:backgroundTint="@color/white"
                    android:textColor="@color/text_gray"
                    android:layout_marginEnd="4dp"/>
                <Button
                    android:id="@+id/btnTahun2025"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="2025"
                    android:backgroundTint="@color/white"
                    android:textColor="@color/text_gray"
                    android:layout_marginHorizontal="4dp"/>
                <Button
                    android:id="@+id/btnTahun2026"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="2026"
                    android:backgroundTint="@color/orange_primary"
                    android:textColor="@color/white"
                    android:layout_marginStart="4dp"/>
            </LinearLayout>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="#FFF5ED">
                <TextView
                    android:id="@+id/tvStatusLaporan"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:text="Pilih tahun untuk melihat status laporan."
                    android:textColor="@color/text_dark"/>
            </androidx.cardview.widget.CardView>

            <Button
                android:id="@+id/btnUnduhLaporan"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Unduh Laporan Tahunan (PDF)"
                android:backgroundTint="#BDBDBD"
                android:textColor="@color/white"
                android:enabled="false"
                android:layout_marginBottom="12dp"/>

            <Button
                android:id="@+id/btnShareLaporan"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Bagikan Tautan Transparansi"
                android:backgroundTint="@color/white"
                android:textColor="@color/orange_primary"/>
        </LinearLayout>
    </ScrollView>
</LinearLayout>